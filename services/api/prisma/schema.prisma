generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLAYER
  ADMIN
  SUPPORT
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum BonusType {
  WELCOME
  DAILY
  CASHBACK
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  username         String         @unique
  passwordHash     String
  role             Role           @default(PLAYER)
  isBanned         Boolean        @default(false)
  bannedAt         DateTime?
  lastLogin        DateTime?
  refreshTokenHash String?
  lastBonusClaim   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  wallet           Wallet?
  sessions         GameSession[]
  ledgerEntries    LedgerEntry[]
  leaderboard      Leaderboard[]
  userBonuses      UserBonus[]
}

model Wallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  balance            Decimal  @default(0) @db.Decimal(18, 2)
  freeSpinsRemaining Int      @default(0)
  version            Int      @default(0)
  updatedAt          DateTime @updatedAt
}

model LedgerEntry {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  type          LedgerType
  amount        Decimal    @db.Decimal(18, 2)
  balanceBefore Decimal    @db.Decimal(18, 2)
  balanceAfter  Decimal    @db.Decimal(18, 2)
  referenceId   String?
  createdAt     DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model GameSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  gameType   String
  betAmount  Decimal  @db.Decimal(18, 2)
  winAmount  Decimal  @db.Decimal(18, 2)
  result     Json
  serverSeed String
  nonce      Int
  createdAt  DateTime @default(now())

  @@index([userId])
}

model BonusConfig {
  id            String    @id @default(cuid())
  type          BonusType @unique
  enabled       Boolean   @default(true)
  // amount in VCOIN; for DAILY this is the Bronze-tier baseline
  baseAmount    Decimal   @db.Decimal(18, 2)
  // tier multipliers stored as JSON: { silver: 2, gold: 4, platinum: 10 }
  tierMultipliers Json    @default("{\"SILVER\":2,\"GOLD\":4,\"PLATINUM\":10}")
  // cashback rate as a percentage (e.g. 5 = 5%)
  cashbackPct   Decimal   @db.Decimal(5, 2) @default(5)
  expiresInDays Int       @default(7)
  updatedAt     DateTime  @updatedAt
}

model UserBonus {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      BonusType
  amount    Decimal   @db.Decimal(18, 2)
  expiresAt DateTime?
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gameType  String
  period    String
  score     Decimal  @db.Decimal(18, 2)
  rank      Int
  createdAt DateTime @default(now())

  @@unique([userId, gameType, period])
  @@index([gameType, period])
}

model Jackpot {
  id         String   @id @default(cuid())
  gameType   String   @unique
  amount     Decimal  @db.Decimal(18, 2)
  seedAmount Decimal  @db.Decimal(18, 2)
  updatedAt  DateTime @updatedAt
}
