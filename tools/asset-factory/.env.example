# Asset Factory — Environment Variables
# Copy this file to .env in the repo root and fill in values.
# Never commit actual keys. .env is gitignored.

# ── Provider selection ────────────────────────────────────────────────────────
# Which image generation service to use.
# Options: gemini | nano-banana | manual
ASSET_PROVIDER=manual

# ── Gemini (Google AI Studio / Vertex AI) ────────────────────────────────────
# Required when ASSET_PROVIDER=gemini
# Obtain from: https://ai.google.dev/gemini-api/keys
GEMINI_API_KEY=

# ── Nano Banana ───────────────────────────────────────────────────────────────
# Required when ASSET_PROVIDER=nano-banana
NANO_BANANA_API_KEY=

# ── Output configuration ──────────────────────────────────────────────────────
# Root directory for generated web assets (relative to repo root).
# Default: apps/web/public/assets
# Changing this is not recommended — paths are hardcoded in manifest.json.
# ASSET_OUTPUT_DIR=apps/web/public/assets

# ── Optional: Rate limiting ───────────────────────────────────────────────────
# Milliseconds to wait between API requests (default: 3000).
# Increase if hitting provider rate limits.
# ASSET_RATE_LIMIT_MS=3000
