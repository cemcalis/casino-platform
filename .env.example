# Local development defaults.
# Copy this file to .env and adjust as needed.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=casino
POSTGRES_USER=casino
POSTGRES_PASSWORD=casino_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://casino:casino_dev@localhost:5432/casino

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── API (services/api) ────────────────────────────────────────────────────────
API_PORT=4000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 cryptographically random bytes required. Never reuse between envs.
JWT_ACCESS_SECRET=REPLACE_WITH_32_PLUS_BYTE_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_32_PLUS_BYTE_RANDOM_HEX
