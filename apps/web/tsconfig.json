{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "paths": {
      "@casino/ui": ["../../packages/ui/src/index.ts"],
      "@casino/theme": ["../../packages/theme/src/index.ts"],
      "@casino/slot-runtime": ["../../packages/slot-runtime/src/index.ts"],
      "@casino/audio": ["../../packages/audio/src/index.ts"],
      "@casino/animation": ["../../packages/animation/src/index.ts"],
      "@casino/types": ["../../packages/types/src/index.ts"],
      "@casino/engine": ["../../packages/engine/src/index.ts"],
      "@casino/config": ["../../packages/config/src/index.ts"],
      "@casino/rng": ["../../packages/rng/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
